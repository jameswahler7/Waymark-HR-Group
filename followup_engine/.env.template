# Waymark Cold Email Engine v2 — environment template
#
# Copy this file to `.env` in the same directory and fill in real values.
# Do NOT commit the .env file — it is gitignored.
#
#   cp .env.template .env
#   open -e .env
#
# All values are single line, no spaces around `=`, no quotes.

# --- REQUIRED for engine to run ---------------------------------------------

# Anthropic API key. Get one from https://console.anthropic.com/settings/keys
# Used by enrichment.py + email_generator.py.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# --- REQUIRED for Phase 3 push notifications --------------------------------

# Pushover credentials. Sign up at https://pushover.net (free) and create an
# Application named "Waymark Cold Email Engine" to get an API token. The
# User Key is on your Pushover dashboard top-right.
# Used by notifier.py.
PUSHOVER_USER_KEY=REPLACE_WITH_YOUR_PUSHOVER_USER_KEY
PUSHOVER_API_TOKEN=REPLACE_WITH_YOUR_PUSHOVER_APP_API_TOKEN

# Optional: restrict pushes to a single named device from your Pushover
# account (leave blank to push to all your devices).
PUSHOVER_DEVICE=

# --- OPTIONAL overrides -----------------------------------------------------

# Where the daily report email is delivered. Default: Jamie's main mailbox.
# WAYMARK_REPORT_TO=Jamie.wahler@waymarkhrgroup.com

# Where Pushover failure backup alerts are emailed. Default uses Gmail
# +addressing so a single filter can label them.
# WAYMARK_ALERT_EMAIL=Jamie.wahler+alerts@waymarkhrgroup.com

# Anthropic models. Default to the latest Sonnet at build time.
# WAYMARK_ENRICHMENT_MODEL=claude-sonnet-4-5
# WAYMARK_GENERATION_MODEL=claude-sonnet-4-5

